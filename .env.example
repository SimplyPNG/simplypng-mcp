# SimplyPNG API key — required
# Get yours at https://simplypng.app/dashboard/api-keys
# Format: sp_live_xxxx (production) or sp_test_xxxx (testing)
SIMPLYPNG_API_KEY=sp_live_your_key_here

# Base URL — optional, defaults to https://simplypng.app
# Override for staging: https://staging.simplypng.app
SIMPLYPNG_API_URL=https://simplypng.app

# HTTP server port — only used when running in HTTP transport mode (npm run serve)
PORT=3000
