# Copy this file to .env and fill in your values.
# cp .env.example .env
#
# This file is auto-loaded by the server (dotenv). No need to set env vars manually.

# SimplyPNG API key — REQUIRED
# Create one at: https://simplypng.app/dashboard/api-keys
# IMPORTANT: Use the key from your SimplyPNG API dashboard, NOT from saas/.env.local
# Format: sp_live_xxxx (production) or sp_test_xxxx (staging)
SIMPLYPNG_API_KEY=sp_live_your_key_here

# Base URL — optional, defaults to https://simplypng.app
# Override for staging only: SIMPLYPNG_API_URL=https://staging.simplypng.app
# SIMPLYPNG_API_URL=https://simplypng.app

# HTTP server port — only used by npm run serve (HTTP transport mode)
# PORT=3000
